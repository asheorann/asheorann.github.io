---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => {
  return b.data.date.getTime() - a.data.date.getTime();
});

function formatDate(date: Date): string {
  const month = date.toLocaleDateString('en-US', { month: 'long' }).toLowerCase();
  const year = date.getFullYear();
  return `${month} ${year}`;
}
---

<BaseLayout title="Building — Anushka Sheoran">
  <div class="page-header">
    <div class="container">
      <h1>building</h1>
    </div>
  </div>

  <div class="container">
    {sortedProjects.length > 0 ? (
      <div class="project-list">
        {sortedProjects.map(project => (
          <article class="project-card">
            <div class="project-meta mono-lower muted">
              <time>{formatDate(project.data.date)}</time>
            </div>
            <h2>
              {project.data.hasFullPage ? (
                <a href={`/building/${project.slug}`}>{project.data.title}</a>
              ) : (
                <span>{project.data.title}</span>
              )}
            </h2>
            <p class="summary">{project.data.summary}</p>
            {project.data.bullets && project.data.bullets.length > 0 && (
              <ul class="project-bullets">
                {project.data.bullets.map(bullet => (
                  <li>{bullet}</li>
                ))}
              </ul>
            )}
            {project.data.takeaway && (
              <p class="takeaway">{project.data.takeaway}</p>
            )}
            <div class="project-footer">
              {project.data.tags && project.data.tags.length > 0 && (
                <span class="tags mono-lower">
                  {project.data.tags.map((tag, i) => (
                    <>{i > 0 && ', '}{tag}</>
                  ))}
                </span>
              )}
              {project.data.links && project.data.links.length > 0 && (
                <div class="project-links">
                  {project.data.links.map(link => (
                    <a href={link.url} target="_blank" rel="noopener" class="project-link-item mono-lower">[ {link.label} ]</a>
                  ))}
                </div>
              )}
            </div>
            {project.data.note && (
              <p class="project-note muted">{project.data.note}</p>
            )}
          </article>
        ))}
      </div>
    ) : (
      <p class="muted">[No projects yet]</p>
    )}
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: var(--space-4) 0 var(--space-2);
    border-bottom: 1px solid var(--border);
  }

  .page-header h1 {
    font-size: var(--text-3xl);
    text-transform: lowercase;
  }

  .project-list {
    padding: var(--space-4) 0;
    display: grid;
    gap: var(--space-4);
  }

  .project-card {
    padding: var(--space-2);
    border: 1px solid var(--border);
    background: var(--surface);
    transition: border-color 200ms ease;
    border-radius: 6px;
  }

  .project-card:hover {
    border-color: var(--accent);
  }

  .project-meta {
    margin-bottom: 0.5rem;
    font-size: 0.8125rem;
  }

  .project-card h2 {
    font-size: var(--text-xl);
    margin-bottom: 0.75rem;
  }

  .project-card h2 a {
    color: var(--text);
    border: none;
  }

  .project-card h2 a:hover {
    color: var(--accent);
  }

  .project-card h2 span {
    color: var(--text);
  }

  .summary {
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .project-bullets {
    list-style: none;
    margin: 0 0 0.75rem 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .project-bullets li {
    font-size: 0.875rem;
    line-height: 1.4;
    padding-left: 1rem;
    position: relative;
    color: var(--muted);
  }

  .project-bullets li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: bold;
  }

  .takeaway {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--muted);
    font-style: italic;
    margin-bottom: 0.75rem;
  }

  .project-footer {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .tags {
    font-size: 0.75rem;
    color: var(--accent);
  }

  .project-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .project-link-item {
    font-size: 0.75rem;
    color: var(--accent);
    text-decoration: none;
    border: none;
    transition: color 200ms ease;
  }

  .project-link-item:hover {
    color: var(--text);
    border: none;
  }

  .project-note {
    font-size: 0.8125rem;
    margin-top: 0.75rem;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .page-header {
      padding: var(--space-2) 0 var(--space-1);
    }

    .project-list {
      padding: var(--space-2) 0;
      gap: var(--space-2);
    }
  }
</style>
