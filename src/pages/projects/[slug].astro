---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await project.render();
---

<BaseLayout title={`${project.data.title} — Anushka Sheoran`}>
  <article class="project">
    <header class="project-header">
      <div class="container prose">
        <div class="project-meta mono-lower muted">
          <time>
            {project.data.startDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short'
            })}
            {project.data.endDate && (
              <>
                {' — '}
                {project.data.endDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short'
                })}
              </>
            )}
          </time>
          <span class="separator">·</span>
          <span class="tags" style="color: var(--accent);">
            {project.data.tags.map((tag, i) => (
              <>{i > 0 && ', '}{tag}</>
            ))}
          </span>
        </div>
        <h1>{project.data.title}</h1>
        <p class="summary">{project.data.summary}</p>
        {(project.data.link || project.data.repo) && (
          <div class="project-links">
            {project.data.link && (
              <a href={project.data.link} target="_blank" rel="noopener">
                view project
              </a>
            )}
            {project.data.repo && (
              <a href={project.data.repo} target="_blank" rel="noopener">
                view code
              </a>
            )}
          </div>
        )}
      </div>
    </header>

    <div class="project-content container prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .project {
    padding: var(--space-4) 0;
  }

  .project-header {
    margin-bottom: var(--space-4);
  }

  .project-meta {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    align-items: baseline;
  }

  .separator {
    color: var(--muted);
  }

  .project-header h1 {
    font-size: var(--text-3xl);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .summary {
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--muted);
    margin-bottom: var(--space-2);
  }

  .project-links {
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .project-content {
    font-size: var(--text-base);
    line-height: 1.65;
  }

  .project-content :global(h2) {
    margin-top: var(--space-4);
    margin-bottom: var(--space-1);
  }

  .project-content :global(h3) {
    margin-top: var(--space-2);
    margin-bottom: var(--space-1);
  }

  .project-content :global(p) {
    margin-bottom: var(--space-2);
  }

  .project-content :global(ul),
  .project-content :global(ol) {
    margin-bottom: var(--space-2);
  }

  .project-content :global(li) {
    margin-bottom: 0.75rem;
  }

  .project-content :global(img) {
    margin: var(--space-2) 0;
    border: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .project {
      padding: var(--space-2) 0;
    }

    .project-header {
      margin-bottom: var(--space-2);
    }
  }
</style>
