---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const thoughts = await getCollection('thoughts');
  return thoughts.map(thought => ({
    params: { slug: thought.slug },
    props: { thought },
  }));
}

const { thought } = Astro.props;
const { Content } = await thought.render();
---

<BaseLayout title={`${thought.data.title} — Anushka Sheoran`}>
  <article class="post">
    <header class="post-header">
      <div class="container prose">
        <div class="post-meta">
          <time class="mono-lower muted">
            {thought.data.date.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric'
            })}
          </time>
          <span class="status mono-lower" style="color: var(--accent);">
            [{thought.data.status}]
          </span>
        </div>
        <h1>{thought.data.title}</h1>
      </div>
    </header>

    <div class="post-content container prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    padding: var(--space-4) 0;
  }

  .post-header {
    margin-bottom: var(--space-4);
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    align-items: baseline;
  }

  .post-header h1 {
    font-size: var(--text-3xl);
    line-height: 1.2;
  }

  .post-content {
    font-size: var(--text-base);
    line-height: 1.65;
  }

  .post-content :global(h2) {
    margin-top: var(--space-4);
    margin-bottom: var(--space-1);
  }

  .post-content :global(h3) {
    margin-top: var(--space-2);
    margin-bottom: var(--space-1);
  }

  .post-content :global(p) {
    margin-bottom: var(--space-2);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: var(--space-2);
  }

  .post-content :global(li) {
    margin-bottom: 0.75rem;
  }

  @media (max-width: 768px) {
    .post {
      padding: var(--space-2) 0;
    }

    .post-header {
      margin-bottom: var(--space-2);
    }
  }
</style>
